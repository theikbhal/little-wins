{
  "manifest_version": 3,
  "name": "Little Wins",
  "version": "1.0.0",
  "description": "Celebrate small wins, one focus, zikir counter — ADHD-friendly",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  }
}
